# Host port the docker-compose Postgres binds to. Override if 5432 is
# already in use (e.g. a system Postgres install on Windows). The port in
# DATABASE_URL below MUST match this value — `pnpm db:migrate` runs a
# preflight that fails fast on drift (and on a shell-exported
# DATABASE_URL that disagrees with this file). See README §10.
PULSE5_PG_HOST_PORT=5432
DATABASE_URL=postgres://pulse5:pulse5@localhost:5432/pulse5

POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_RTDS_WS_URL=wss://ws-live-data.polymarket.com
POLYMARKET_RTDS_SPONSOR_KEY=

LOG_LEVEL=info
DISCOVERY_INTERVAL_MS=5000
HEALTH_LOG_INTERVAL_MS=30000
